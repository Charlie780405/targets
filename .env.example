# 复制为 .env（.env 已被 gitignore，绝不入库）

# --- 数据库 ---
# MVP 单机：SQLite（默认）
DATABASE_URL=sqlite:///data/target_intel.sqlite
# 云端正式：PostgreSQL
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/target_intel

# --- NCBI E-utilities（PubMed）---
# 注册 API key 后配额更高；留空则用匿名较低配额
NCBI_API_KEY=
NCBI_TOOL=target-intelligence
NCBI_EMAIL=you@example.com

# --- LLM（结构化抽取 / 摘要，情报层用）---
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# --- 采集礼貌策略 ---
HTTP_USER_AGENT=target-intelligence/0.1 (+https://targets.qyunsgen.com)
HTTP_MAX_RPS=3

# --- Obsidian 同步（私有 Git 仓库）---
VAULT_GIT_REMOTE=
VAULT_LOCAL_PATH=

# --- 告警 ---
SENTRY_DSN=
ALERT_EMAIL_TO=
