# 复制为 .env（.env 已被 gitignore，绝不入库）
# Vultr amd64 部署：cp .env.example .env 后按需填写密钥

# --- 数据库 ---
# systemd / 本机绝对路径（推荐生产）
DATABASE_URL=sqlite:////home/dev/Targets/data/target_intel.sqlite
# 相对路径（仅在仓库根目录手动运行时）
# DATABASE_URL=sqlite:///data/target_intel.sqlite
# 云端正式：PostgreSQL
# DATABASE_URL=postgresql+psycopg://user:pass@127.0.0.1:5432/target_intel

# --- Vault（Obsidian 同步）---
VAULT_PATH=/home/dev/Targets/vault
# 私有 Git 仓库 SSH URL；留空则仅本地 commit
VAULT_GIT_REMOTE=

# --- NCBI E-utilities（PubMed）---
NCBI_API_KEY=
NCBI_TOOL=target-intelligence
NCBI_EMAIL=Charlie780405@outlook.com

# --- LLM（结构化抽取 / 摘要）---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- 采集礼貌策略 ---
HTTP_USER_AGENT=target-intelligence/0.1 (+https://targets.qyunsgen.com)
HTTP_MAX_RPS=3

# --- 健康检查 / Docker ---
SERVICE_NAME=target-intelligence

# --- 告警（001f 预留，尚未接线）---
SENTRY_DSN=
ALERT_EMAIL_TO=
